{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "expo-router/src/*": ["./node_modules/expo-router/build/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "web-build",
    "babel.config.js",
    "metro.config.js"
  ]
}
